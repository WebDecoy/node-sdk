{
  "name": "@webdecoy/client",
  "version": "0.3.0",
  "description": "Web Decoy browser widget - signal collection, proof-of-work, and captcha UI",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "browser": "./dist/webdecoy.global.js",
  "exports": {
    ".": {
      "require": "./dist/index.js",
      "import": "./dist/index.mjs",
      "types": "./dist/index.d.ts"
    },
    "./global": "./dist/webdecoy.global.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "jest",
    "lint": "eslint src/**/*.ts",
    "clean": "rm -rf dist"
  },
  "keywords": [
    "web-decoy",
    "captcha",
    "bot-detection",
    "proof-of-work",
    "browser",
    "fingerprinting"
  ],
  "author": "Web Decoy",
  "license": "MIT",
  "homepage": "https://github.com/WebDecoy/node-sdk#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/WebDecoy/node-sdk.git",
    "directory": "packages/client"
  },
  "bugs": {
    "url": "https://github.com/WebDecoy/node-sdk/issues"
  },
  "devDependencies": {
    "@types/jest": "^29.5.11",
    "@types/node": "^20.11.0",
    "@typescript-eslint/eslint-plugin": "^6.18.1",
    "@typescript-eslint/parser": "^6.18.1",
    "eslint": "^8.56.0",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "ts-jest": "^29.1.1",
    "tsup": "^8.0.1",
    "typescript": "^5.3.3"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
